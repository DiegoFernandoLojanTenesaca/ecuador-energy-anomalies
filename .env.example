# Ecuador Energy Anomaly Detector - Environment Variables

# Scraping settings
SCRAPER_DELAY_SECONDS=3
SCRAPER_MAX_RETRIES=3
SCRAPER_CACHE_DIR=data/cache

# Data paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# Model settings
MODEL_CONTAMINATION=auto
MODEL_N_ESTIMATORS=200
MODEL_RANDOM_STATE=42

# HuggingFace (for deployment)
# HF_TOKEN=your_token_here
